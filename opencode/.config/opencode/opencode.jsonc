{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./prompts/system.txt}",
      "reasoningEffort": "high"
    },
    "explore": {
      "model": "openai/gpt-5.4",
    }
  },
  "plugin": [],
  "mcp": {
    "imcp": {
      "type": "local",
      "command": ["/Applications/iMCP.app/Contents/MacOS/imcp-server"],
      "enabled": false
    },
    "xcodebuildmcp": {
      "type": "local",
      "command": ["bun", "x", "-y", "xcodebuildmcp@latest"],
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": false
    }
  },
  "permission": {
    "external_directory": {
      "*": "allow",
      "{env:HOME}/.config/opencode/skills/*": "allow"
    }
  },
  "autoupdate": true
}
