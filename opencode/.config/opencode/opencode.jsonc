{
  "$schema": "https://opencode.ai/config.json",
  // "model": "opencode/claude-opus-4-6",
  "model": "openai/gpt-5.4",
  "agent": {
    "build": {
      "mode": "primary",
      // "model": "opencode/claude-opus-4-6",
      // "prompt": "{file:./prompts/anthropic.txt}",
      // "reasoningEffort": "none"
      "model": "openai/gpt-5.4",
      "prompt": "{file:./prompts/codex.txt}",
      "reasoningEffort": "medium"
    },
    "plan": {
      "mode": "primary",
      // "model": "opencode/claude-opus-4-6",
      // "prompt": "{file:./prompts/anthropic.txt}",
      // "reasoningEffort": "high"
      "model": "openai/gpt-5.4",
      "prompt": "{file:./prompts/codex.txt}",
      "reasoningEffort": "high"
    },
    "explore": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "low"
    }
  },
  "plugin": [],
  "mcp": {
    "xcodebuildmcp": {
      "type": "local",
      "command": ["bun", "x", "-y", "xcodebuildmcp@latest"],
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": false
    }
  },
  "permission": {
    "external_directory": {
      "*": "ask",
      "{env:HOME}/.config/opencode/skills/*": "allow"
    }
  },
  "provider": {
    "openai": {
      "models": {
        "gpt-5.4": {
          "options": {
            "serviceTier": "priority"
          }
        }
      }
    },
  },
  "autoupdate": true
}
