{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-6",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:./prompts/system.txt}",
    },
    "explore": {
      "model": "openai/gpt-5.4-mini",
    }
  },
  "plugin": [],
  "mcp": {
    "xcodebuildmcp": {
      "type": "local",
      "command": ["bun", "x", "-y", "xcodebuildmcp@latest"],
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": false
    }
  },
  "permission": {
    "external_directory": {
      "*": "allow",
      "{env:HOME}/.config/opencode/skills/*": "allow"
    }
  },
  "autoupdate": true
}
