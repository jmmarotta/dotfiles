shell-integration = zsh
theme = "light:Everforest Light Soft,dark:Everforest Dark Medium"
font-family = "JetBrainsMono Nerd Font Mono"
font-size = 14

window-save-state = always
window-inherit-working-directory = true
tab-inherit-working-directory = true
split-inherit-working-directory = true
unfocused-split-opacity = 0.9
split-preserve-zoom = navigation
macos-option-as-alt = left
copy-on-select = clipboard
confirm-close-surface = true
scrollback-limit = 50000000

keybind = ctrl+space=activate_key_table:tmux

keybind = tmux/c=new_tab
keybind = chain=deactivate_key_table
keybind = tmux/n=next_tab
keybind = chain=deactivate_key_table
keybind = tmux/p=previous_tab
keybind = chain=deactivate_key_table
keybind = tmux/w=toggle_tab_overview
keybind = chain=deactivate_key_table
keybind = tmux/shift+digit_5=new_split:right
keybind = chain=deactivate_key_table
keybind = tmux/shift+quote=new_split:down
keybind = chain=deactivate_key_table
keybind = tmux/shift+t=new_split:right
keybind = chain=goto_split:left
keybind = chain=new_split:down
keybind = chain=deactivate_key_table
keybind = tmux/h=goto_split:left
keybind = chain=deactivate_key_table
keybind = tmux/j=goto_split:down
keybind = chain=deactivate_key_table
keybind = tmux/k=goto_split:up
keybind = chain=deactivate_key_table
keybind = tmux/l=goto_split:right
keybind = chain=deactivate_key_table
keybind = tmux/shift+h=resize_split:left,1000
keybind = chain=deactivate_key_table
keybind = tmux/shift+j=resize_split:down,1000
keybind = chain=deactivate_key_table
keybind = tmux/shift+k=resize_split:up,1000
keybind = chain=deactivate_key_table
keybind = tmux/shift+l=resize_split:right,1000
keybind = chain=deactivate_key_table
keybind = tmux/z=toggle_split_zoom
keybind = chain=deactivate_key_table
keybind = tmux/equal=equalize_splits
keybind = chain=deactivate_key_table
keybind = tmux/1=goto_tab:1
keybind = chain=deactivate_key_table
keybind = tmux/2=goto_tab:2
keybind = chain=deactivate_key_table
keybind = tmux/3=goto_tab:3
keybind = chain=deactivate_key_table
keybind = tmux/4=goto_tab:4
keybind = chain=deactivate_key_table
keybind = tmux/5=goto_tab:5
keybind = chain=deactivate_key_table
keybind = tmux/6=goto_tab:6
keybind = chain=deactivate_key_table
keybind = tmux/7=goto_tab:7
keybind = chain=deactivate_key_table
keybind = tmux/8=goto_tab:8
keybind = chain=deactivate_key_table
keybind = tmux/9=goto_tab:9
keybind = chain=deactivate_key_table
keybind = tmux/0=last_tab
keybind = chain=deactivate_key_table
keybind = tmux/[=activate_key_table:copy_mode
# cmd+shift+j works better for opening scrollback in an editor: start in bash,
# type `nvim`, then press the keybind to insert the scrollback filepath and open it.
keybind = tmux/s=write_scrollback_file:open
keybind = chain=deactivate_key_table
keybind = tmux/r=deactivate_key_table
keybind = chain=reload_config
keybind = tmux/q=close_surface
keybind = chain=deactivate_key_table
keybind = tmux/ctrl+c=deactivate_key_table
keybind = tmux/ctrl+space=deactivate_key_table
keybind = tmux/escape=deactivate_key_table
keybind = tmux/catch_all=ignore

keybind = copy_mode/j=scroll_page_lines:1
keybind = copy_mode/k=scroll_page_lines:-1
keybind = copy_mode/ctrl+d=scroll_page_fractional:0.5
keybind = copy_mode/ctrl+u=scroll_page_fractional:-0.5
keybind = copy_mode/ctrl+f=scroll_page_down
keybind = copy_mode/ctrl+b=scroll_page_up
keybind = copy_mode/shift+j=scroll_page_down
keybind = copy_mode/shift+k=scroll_page_up
keybind = copy_mode/g>g=scroll_to_top
keybind = copy_mode/shift+g=scroll_to_bottom
keybind = copy_mode/slash=start_search
keybind = copy_mode/n=navigate_search:next
keybind = copy_mode/shift+n=navigate_search:previous
keybind = copy_mode/y=copy_to_clipboard:plain
keybind = chain=deactivate_all_key_tables
keybind = copy_mode/ctrl+c=deactivate_all_key_tables
keybind = copy_mode/ctrl+space=deactivate_all_key_tables
keybind = copy_mode/escape=deactivate_all_key_tables
keybind = copy_mode/q=deactivate_all_key_tables
keybind = copy_mode/i=deactivate_all_key_tables
keybind = copy_mode/catch_all=ignore
